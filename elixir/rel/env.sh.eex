#!/bin/sh
# Runtime environment for OTP release
# Copy to a secure location and source before starting: source /etc/ledger_bot/env.sh

export TELEGRAM_BOT_TOKEN="${TELEGRAM_BOT_TOKEN:?TELEGRAM_BOT_TOKEN must be set}"
export ADMIN_TELEGRAM_ID="${ADMIN_TELEGRAM_ID:?ADMIN_TELEGRAM_ID must be set}"
export DATABASE_PATH="${DATABASE_PATH:-/var/lib/ledger_bot/ledger.db}"
